#!/usr/bin/env bash
#MISE description="Extract CHANGELOG section for a given version tag (vX.Y.Z)"
set -euo pipefail

VERSION="${1:?usage: release-notes vX.Y.Z}"
NUMBER="${VERSION#v}"

notes="$(awk -v v="$NUMBER" '
    $0 ~ "^## " v { found=1; next }
    found && /^## / { exit }
    found { print }
' CHANGELOG.md)"

if [ -z "$notes" ]; then
    echo "release-notes: no CHANGELOG section for $VERSION" >&2
    exit 1
fi

printf '%s\n' "$notes"
