#!/usr/bin/env bash
#MISE description="Install pinned tools and verify dev environment"
set -euo pipefail

echo "Installing tools pinned in .mise.toml ..."
mise install

ok=true
check() {
    if command -v "$1" &>/dev/null; then
        printf "  %-20s %s\n" "$1" "$(command -v "$1")"
    else
        printf "  %-20s MISSING — %s\n" "$1" "$2"
        ok=false
    fi
}

echo ""
echo "Checking dev tools:"
check go              "run 'mise install' or check that mise is activated in your shell"
check golangci-lint   "run 'mise install' or check that mise is activated in your shell"
check tparse          "run 'mise install' or check that mise is activated in your shell"
check goimports       "run 'mise install' or check that mise is activated in your shell"
check govulncheck     "run 'mise install' or check that mise is activated in your shell"
check go-licenses     "run 'mise install' or check that mise is activated in your shell"
check pre-commit      "run 'mise install' or check that mise is activated in your shell"
echo ""
if $ok; then
    echo "All tools installed."
    echo "Run 'pre-commit install' to set up git hooks."
else
    echo "Some tools are missing. Run 'mise install' and try again."
    exit 1
fi
